# LLM provider (OpenAI-compatible endpoint)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o

# Server config
HOST=0.0.0.0
PORT=80
PUBLIC_URL=http://your-server-ip

# Arena timing (seconds)
INTERMISSION_SEC=30
POST_MATCH_SEC=10
MATCH_INTERVAL_SEC=300

# Google Gemini (for thumbnail generation)
GOOGLE_API_KEY=your-google-api-key
